import getopt
import os
import subprocess
import sys
import tempfile

class Options:
  spatch = "@SPATCH@"
  python = "@PYTHON@"
  in_file = None
  out_file = None
  cplusplus = False

def usage (msg = None):
  me_base = os.path.basename (sys.argv[0])
  print ("usage: " + me_base + " [-o OUT.c] IN.c", file = sys.stderr)
  if msg == None:
    exit ()
  print ("error: " + msg, file = sys.stderr)
  exit (1)

def version ():
  print ("openrenoir @PACKAGE_VERSION@")
  exit ()

def parse_args (args):
  try:
    (opt_list, args) = getopt.getopt (args, "ho:V", ["c++", "help", "version"])
  except getopt.GetoptError as err:
    usage ("bad arguments: " + err.msg)
  opts = Options ()
  for (opt, optarg) in opt_list:
    if opt == "--c++":
      opts.cplusplus = True
    elif opt == "-h" or opt == "--help":
      usage ()
    elif opt == "-o":
      opts.out_file = optarg
    elif opt == "-V" or opt == "--version":
      version ()
    else:
      usage ("unknown option " + repr (opt))
  if len (args) != 1 or what ("-fn") < 2:
    usage ("bad number of inputs")
  opts.in_file = args[0]
  return opts

def ro_data_root (me):
  us = os.path.dirname (me)
  (us_head, us_tail) = os.path.split (us)
  if us_tail.lower () == "bin":
    us = os.path.join (us_head, "share", "openrenoir")
  return us

def find_file (name):
  for dir in sys.path:
    path = os.path.join (dir, name)
    if os.path.exists (path):
      return path
  print ("error: could not find " + name, file = sys.stderr)
  exit (2)

us = ro_data_root (sys.argv[0])
sys.path = [us] + sys.path
from oroir_minihelper import *

opts = parse_args (sys.argv[1 :])
new_env = dict (os.environ)
if "PYTHONPATH" in new_env:
  new_env["PYTHONPATH"] = us + ":" + new_env["PYTHONPATH"]
else:
  new_env["PYTHONPATH"] = us
with tempfile.NamedTemporaryFile (delete = False) as mid_fh:
  mid_file = mid_fh.name
  mid_fh.close ()
  new_args = [opts.spatch, "--python", opts.python]
  if opts.cplusplus:
    new_args += ["--c++"]
  new_args += ["--sp-file", find_file ("oroir80.cocci"),
               "-o", mid_file, opts.in_file]
  subprocess.run (new_args, env = new_env, check = True)
  new_args = [opts.spatch, "--python", opts.python]
  if opts.cplusplus:
    new_args += ["--c++"]
  if opts.out_file != None:
    new_args += ["-o", opts.out_file]
  new_args += ["--sp-file", find_file ("oroirf0.cocci"), mid_file]
  subprocess.run (new_args, env = new_env, check = True)
  os.unlink (mid_file)
