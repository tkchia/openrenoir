import os
import re
import string
import sys
sys.path = ["@abs_srcdir@"] + sys.path
from oroir_minihelper import *

class IdCharMap (dict):
  def __missing__ (self, key):
    return "_"

lineno_re = re.compile (r"\b__LINE__\b")
uint_lit_re = re.compile \
                (r"\b([123456789][0123456789]*"
                 + r"|[01234567][01234567]*"
                 + r"|0[xX][0123456789abcdefABCDEF]+)"
                 + r"[uU]?([lL][lL]?)\b")
id_xlat = IdCharMap ({ ord (c): c
		       for c in string.digits + string.ascii_letters + "_" })

assert (len (sys.argv) > 2)
srcdir = sys.argv[1]
print ("# automatically generated by " + os.path.basename (sys.argv[0]))
for in_file in sys.argv[2 :]:
  if os.path.commonpath ([in_file, srcdir]) == srcdir:
    in_file_base = os.path.relpath (in_file, srcdir)
  else:
    in_file_base = os.path.relpath (in_file)
  sym_base = in_file_base.translate (id_xlat)
  sym_idx = 0
  with open (in_file, encoding = "utf-8") as in_fh:
    lineno = 0
    for line in in_fh:
      lineno += 1
      if lineno_re.search (line) != None and what ("ol") > 1:
        sym_idx += 1
        print ("lineno_" + sym_base + "_" + str (sym_idx)
               + " = " + str (lineno))
        lit_idx = 0
        for mat in uint_lit_re.finditer (line):
          lit_idx += 1
          print ("lit_" + sym_base + "_" + str (sym_idx)
                 + "_" + str (lit_idx) + " = " + mat.group (1))
