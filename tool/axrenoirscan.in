import getopt
import os
import shutil
import subprocess
import sys
import tempfile

def get_ac_paths (autoscan):
  if "autom4te_perllibdir" in os.environ:
    ac_paths = [os.environ["autom4te_perllibdir"]]
  else:
    ac_path = "@datarootdir@/autoconf"
    if ac_path[: 10] == "${prefix}/":
      ac_bin_dir = os.path.dirname (autoscan)
      (ac_bin_head, ac_bin_tail) = os.path.split (ac_bin_dir)
      if ac_bin_tail.lower () == "bin":
        ac_prefix = ac_bin_head
      else:
        ac_prefix = ac_bin_dir
      ac_paths = [os.path.join ("@prefix@", ac_path[10 :]),
                  os.path.join (ac_prefix, ac_path[10 :])]
    else:
      ac_paths = [ac_path]
  return ac_paths

class Options:
  me = os.path.basename (sys.argv[0])
  autoscan = "@AUTOSCAN@"
  autoconf = "@AUTOCONF@"
  ac_paths = get_ac_paths (autoscan)
  passthru = []
  srcdir = "."
  install = False
  install_acdir = None
  install_auxdir = None
  verbose = False

def version_string ():
  return "axrenoirscan @PACKAGE_VERSION@"

def usage (msg = None):
  me = Options.me
  print (version_string (), file = sys.stderr)
  print ("usage:\n"
         + "  " + me + " [AUTOSCAN-OPTIONS...] \\\n"
         + "    [--install [--install-acdir DIR] [--install-auxdir DIR]] "
                + "[SRCDIR]\n"
         + "  " + me + " {-h | -? | --help | -V | --version}",
         file = sys.stderr)
  if msg == None:
    exit ()
  print ("error: " + msg, file = sys.stderr)
  exit (1)

def version ():
  print (version_string ())
  exit ()

def parse_args (args):
  try:
    (opt_list, args) = getopt.getopt (args,
                                      "B:dh?I:vV",
                                      ["prepend-include=", "debug",
                                       "help", "include=",
                                       "install",
                                       "install-acdir=", "install-auxdir=",
                                       "verbose", "version"])
  except getopt.GetoptError as err:
    usage ("bad arguments: " + err.msg)
  opts = Options ()
  for (opt, optarg) in opt_list:
    if opt == "-B" or opt == "--prepend-include":
      opts.ac_paths = [optarg] + opts.ac_paths
      opts.passthru += [opt, optarg]
    elif opt == "-I" or opt == "--include":
      opts.ac_paths += [optarg]
      opts.passthru += [opt, optarg]
    elif opt == "--install":
      opts.install = True
    elif opt == "--install-acdir":
      opts.install_acdir = optarg
    elif opt == "--install-auxdir":
      opts.install_auxdir = optarg
    elif opt == "-h" or opt == "-?" or opt == "--help":
      usage ()
    elif opt == "-v" or opt == "--verbose":
      opts.verbose = True
      opts.passthru += [opt]
    elif opt == "-V" or opt == "--version":
      version ()
    else:
      opts.passthru += [opt]
  if len (args) > 1 or what ("-fn") < 2:
    usage ("bad number of source directories")
  if len (args) == 1:
    opts.srcdir = args[0]
  return opts

def ro_data_root (me):
  us = os.path.dirname (me)
  (us_head, us_tail) = os.path.split (us)
  if us_tail.lower () == "bin":
    us = os.path.join (us_head, "share", "openrenoir")
  return us

def find_file (name, paths):
  for dir in paths:
    path = os.path.join (dir, name)
    if os.path.exists (path):
      return path
  print ("error: could not find " + name + " in", file = sys.stderr)
  for dir in paths:
    print ("  " + dir, file = sys.stderr)
  exit (2)

def info (msg, opts):
  if opts.verbose:
    print (opts.me + ": " + msg, file = sys.stderr)

us = ro_data_root (sys.argv[0])
sys.path = [us] + sys.path
from oroir_minihelper import *

opts = parse_args (sys.argv[1 :])
info (version_string (), opts)
old_list_fn = find_file (os.path.join ("autoscan", "autoscan.list"),
                         opts.ac_paths)
add_list_fn = find_file ("autoscan.add.list", [us])
info ("autoscan.list addendum at " + add_list_fn, opts)
with tempfile.TemporaryDirectory () as tmp_dir:
  new_as_dir = os.path.join (tmp_dir, "autoscan")
  os.mkdir (new_as_dir, mode = 0o700)
  new_list_fn = os.path.join (new_as_dir, "autoscan.list")
  with open (new_list_fn, "w") as new_list:
    for old_list_fn in [add_list_fn, old_list_fn]:
      with open (old_list_fn, "r") as old_list:
        new_list.write (old_list.read ())
  new_args = [opts.autoscan, "-B", tmp_dir] + opts.passthru + [opts.srcdir]
  info ("running " + repr (new_args), opts)
  subprocess.run (new_args, check = True)
if opts.install:
  acdir = opts.install_acdir
  auxdir = opts.install_auxdir
  if acdir == None:
    acdir = opts.srcdir
    info ("acdir = " + acdir, opts)
  if auxdir == None:
    new_args = [opts.autoconf, "--trace=AC_CONFIG_AUX_DIR:$1"]
    info ("running " + repr (new_args), opts)
    result = subprocess.run (new_args, cwd = opts.srcdir,
                             capture_output = True, text = True)
    #
    # Follow autoreconf & use the directory given in the last call to
    # AC_CONFIG_AUX_DIR as the destination.  In my opinion it is equally
    # valid to use the first call instead...
    #
    returncode = result.returncode
    info ("status " + str (returncode), opts)
    if result.returncode == 0:
      trace = result.stdout.rstrip ("\n").split ("\n")
      auxdir = trace[-1]
    else:
      auxdir = opts.srcdir
    info ("auxdir = " + auxdir, opts)
  for m4_base in ["check-absent.m4"]:
    old_m4_fn = find_file (m4_base, [us])
    info ("install " + old_m4_fn + " to acdir", opts)
    try:
      os.mkdir (acdir)
    except FileExistsError:
      pass
    new_m4_fn = os.path.join (acdir, m4_base)
    shutil.copy2 (old_m4_fn, new_m4_fn)
  for aux_base in ["sha1-impl.awk"]:
    old_aux_fn = find_file (aux_base, [us])
    info ("install " + old_aux_fn + " to auxdir", opts)
    try:
      os.mkdir (auxdir)
    except FileExistsError:
      pass
    new_aux_fn = os.path.join (auxdir, aux_base)
    shutil.copy2 (old_aux_fn, new_aux_fn)
