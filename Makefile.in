# https://creativecommons.org/licenses/by-sa/4.0/.

srcdir = @srcdir@
objdir = .
prefix = @prefix@
exec_prefix = @exec_prefix@
bindir = @bindir@
includedir = @includedir@
libdir = @libdir@
datarootdir = @datarootdir@
datadir = @datadir@
acdir = @srcdir@/config/
auxdir = @ac_aux_dir@
OBJEXT = @OBJEXT@
EXEEXT = @EXEEXT@

CC = @CC@
CPPFLAGS = @CPPFLAGS@ -I$(srcdir)/h -I$(objdir)/h
CFLAGS = @CFLAGS@
LDFLAGS = @LDFLAGS@
LIBS = @LIBS@
OBJEXT = @OBJEXT@
EXEEXT = @EXEEXT@
AR = @AR@
RANLIB = @RANLIB@
PYTHON = @PYTHON@
SPATCH = @SPATCH@

DESTDIR =
VPATH = $(srcdir)

TARGETS = $(PROGRAMS) $(HEADERS) $(DATA) $(LIBRARIES)
INTERMEDIATES = $(LIBOBJS) \
		example/ex1.$(OBJEXT) \
		example/ex1.c
PROGRAMS = $(bin_PROGRAMS) $(check_PROGRAMS)
bin_PROGRAMS = tool/axrenoirscan \
	       tool/openrenoir
check_PROGRAMS = test/check-sha1-impl.sh \
		 example/ex1$(EXEEXT)
HEADERS = h/openrenoir/_check_absent.h \
	  $(include_HEADERS)
include_HEADERS = h/openrenoir/openrenoir.h \
		  h/openrenoir/_version.h
DATA = tool/oroir80.cocci \
       tool/oroirf0.cocci \
       tool/oroir_helper.py \
       tool/oroir_minihelper.py \
       tool/autoscan.add.list \
       $(acdir)check-absent.m4 \
       $(auxdir)sha1-impl.awk \
       $(CLEAN_DATA)
CLEAN_DATA = tool/oroir_consts.py
DISTCLEAN_FILES = config.status \
		  config.log \
		  $(CONFIG_FILES)
CONFIG_FILES = Makefile \
	       tool/axrenoirscan \
	       tool/openrenoir \
	       tool/scan_consts.py \
	       h/openrenoir/_version.h
LIBRARIES = a/libopenrenoir.a
LIBSOURCES = a/oroir80_frob.c
LIBOBJS = $(LIBSOURCES:.c=.o)
TEXTS = doc/LICENSE.CC-BY-SA

default: $(TARGETS)
.PHONY: default

distclean maintainer-clean: clean
	$(RM) -f $(DISTCLEAN_FILES)
	-rmdir -p $(dir $(DISTCLEAN_FILES))
.PHONY: distclean maintainer-clean

clean mostlyclean:
	$(RM) -r $(PROGRAMS) $(LIBRARIES) $(INTERMEDIATES) $(CLEAN_DATA)
	$(RM) -r \
	  $(patsubst %,%/__pycache__, \
	    $(dir $(LIBRARIES) $(INTERMEDIATES) $(CLEAN_DATA)))
	-rmdir -p $(dir $(LIBRARIES) $(INTERMEDIATES) $(CLEAN_DATA))
.PHONY: clean mostlyclean

install: install-libraries install-headers install-data install-programs
.PHONY: install

install-libraries: $(LIBRARIES)
	mkdir -p $(DESTDIR)$(libdir)
	cp $^ $(DESTDIR)$(libdir)
.PHONY: install-libraries

install-headers: $(include_HEADERS)
	mkdir -p $(DESTDIR)$(includedir)/openrenoir
	cp $^ $(DESTDIR)$(includedir)/openrenoir
.PHONY: install-headers

install-data: $(DATA)
	mkdir -p $(DESTDIR)$(datadir)/openrenoir
	cp $^ $(DESTDIR)$(datadir)/openrenoir
.PHONY: install-data

install-programs: $(bin_PROGRAMS)
	mkdir -p $(DESTDIR)$(bindir)
	cp $^ $(DESTDIR)$(bindir)
.PHONY: install-programs

uninstall:
	$(RM) -r $(patsubst %,$(DESTDIR)$(libdir)/%,$(notdir $(LIBRARIES))) \
		 $(DESTDIR)$(includedir)/openrenoir \
		 $(DESTDIR)$(datadir)/openrenoir \
		 $(patsubst %,$(DESTDIR)$(bindir)/%,$(notdir $(bin_PROGRAMS)))
	-rmdir -p $(DESTDIR)$(libdir) $(DESTDIR)$(bindir)
.PHONY: uninstall

check: $(check_PROGRAMS)
	for f in $^; \
	  do $$f || exit $$?; done
.PHONY: check

# NOTE: $(LIBRARIES) is for any library files built in this project, while
# $(LDLIBS) & $(LIBS) are for pre-existing system libraries.  GNU autoconf &
# automake apparently use the names $(LIBRARIES) & $(LIBS) the same ways.
%$(EXEEXT): %.$(OBJEXT) $(LIBRARIES)
	mkdir -p $(@D)
	$(CC) $(LDFLAGS) $(TARGET_ARCH) $^ $(LOADLIBES) $(LDLIBS) $(LIBS) -o $@

example/ex1.c: tool/openrenoir tool/oroir_consts.py example/ex1-j.c
	mkdir -p $(@D)
	PYTHONPATH="$(srcdir)/tool$(if $(PYTHONPATH),:$(PYTHONPATH))" \
	  $< -o $@ $(filter %.c,$^)

a/libopenrenoir.a: $(LIBOBJS)
	$(RM) $@
	$(AR) cq $@ $^
	$(RANLIB) $@

%.$(OBJEXT): %.c $(HEADERS) $(TEXTS)
	mkdir -p $(@D)
	$(CC) $(CPPFLAGS) $(CFLAGS) $(TARGET_ARCH) -c $< -o $@
.PRECIOUS: %.$(OBJEXT)

tool/oroir_consts.py: tool/scan_consts.py $(LIBSOURCES)
	mkdir -p $(@D)
	$(PYTHON) $< $(srcdir) $(filter-out %.py,$^) >$@.tmp
	mv $@.tmp $@

# Cancel GNU make's built-in implicit rules.
%.$(OBJEXT): %.c
%$(EXEEXT): %.$(OBJEXT)
%$(EXEEXT): %.c

$(CONFIG_FILES) : %: %.in config.status
	./config.status $@

config.status: configure
	./$@ --recheck
.PRECIOUS: config.status
